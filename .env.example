# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Absolute or relative path to the SQLite database file.
# Defaults to vendor-radar.db in the project root if not set.
DATABASE_PATH=./vendor-radar.db

# ─── SMTP / Email Alerts ──────────────────────────────────────────────────────
# Credentials for the outbound email account used to send renewal alerts.
# Works with any SMTP provider: Gmail, SendGrid, Mailgun, Postmark, etc.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASSWORD=your-app-password   # use an App Password, not your login password
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASSWORD=SG.xxxxxxxxxxxxxxxx
#
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=your-smtp-password

# ─── Alert Settings ───────────────────────────────────────────────────────────
# The email address that receives renewal alert digests.
ALERT_EMAIL=admin@yourcompany.com

# Cron schedule for the daily alert check (default: 8:00 AM every day).
# Uses standard 5-field cron syntax: minute hour day-of-month month day-of-week
# Examples:
#   '0 8 * * *'    — every day at 08:00
#   '0 9 * * 1-5'  — weekdays only at 09:00
#   '0 */6 * * *'  — every 6 hours
ALERT_CRON=0 8 * * *
